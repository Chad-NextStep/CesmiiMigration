# /etc/nginx/sites-available/cesmii.org
#
# Complete nginx site config for cesmii.org.
# Copy to /etc/nginx/sites-available/cesmii.org and symlink:
#
#   sudo cp nginx-example.config /etc/nginx/sites-available/cesmii.org
#   sudo ln -s /etc/nginx/sites-available/cesmii.org /etc/nginx/sites-enabled/cesmii.org
#   sudo nginx -t && sudo systemctl reload nginx
#
# Prerequisites (Ubuntu 24.04):
#   sudo apt install php8.3-fpm php8.3-curl php8.3-xml
#   sudo systemctl enable --now php8.3-fpm
#
# SSL (after DNS is pointed at this server):
#   sudo apt install certbot python3-certbot-nginx
#   sudo certbot --nginx -d cesmii.org -d www.cesmii.org
#   Certbot will fill in the ssl_certificate paths and reload nginx automatically.
#
# Deploy site content:
#   node build.js          # generates out/
#   rsync -av out/ /var/www/cesmii/out/

# ── HTTP: redirect everything to HTTPS ───────────────────────────────────────

server {
    listen 80;
    listen [::]:80;
    server_name cesmii.org www.cesmii.org;

    return 301 https://cesmii.org$request_uri;
}

# ── HTTPS: main site ──────────────────────────────────────────────────────────

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name cesmii.org www.cesmii.org;

    # Filled in by certbot:
    ssl_certificate     /etc/letsencrypt/live/cesmii.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/cesmii.org/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # Redirect www → apex.
    if ($host = www.cesmii.org) {
        return 301 https://cesmii.org$request_uri;
    }

    root  /var/www/cesmii/out;

    # Try index.php before index.html so HubSpot proxy pages are served via PHP-FPM.
    index index.php index.html;

    # Block direct web access to the proxy library — it is an include-only file.
    location = /proxy.php {
        return 404;
    }

    # PHP-FPM for HubSpot proxy pages (index.php).
    # Cache-Control: no-store keeps reverse proxies / CDNs from caching dynamic
    # responses; the disk cache inside proxy.php handles content freshness.
    # Note: nginx add_header does not inherit from outer blocks when a child
    # location defines its own add_header directives, so security headers are
    # repeated in each location block that sets headers.
    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass         unix:/run/php/php8.3-fpm.sock;
        fastcgi_param        SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_read_timeout 15;

        add_header Cache-Control          "no-store"                             always;
        add_header X-Content-Type-Options "nosniff"                              always;
        add_header X-Frame-Options        "SAMEORIGIN"                           always;
        add_header Referrer-Policy        "strict-origin-when-cross-origin"      always;
    }

    # Clean URLs: try exact file, then directory index, then 404.
    location / {
        try_files $uri $uri/ /404.html;
    }

    # 404 page with full site chrome.
    error_page 404 /404.html;
    location = /404.html {
        internal;
    }

    # Aggressive caching for static assets (CSS, JS, images).
    location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp)$ {
        expires 1y;
        add_header Cache-Control          "public, immutable"                    always;
        add_header X-Content-Type-Options "nosniff"                              always;
        add_header X-Frame-Options        "SAMEORIGIN"                           always;
        add_header Referrer-Policy        "strict-origin-when-cross-origin"      always;
        access_log off;
    }

    # Security headers for all other responses (plain HTML, 404, etc.).
    add_header X-Content-Type-Options "nosniff"                                  always;
    add_header X-Frame-Options        "SAMEORIGIN"                               always;
    add_header Referrer-Policy        "strict-origin-when-cross-origin"          always;
}
